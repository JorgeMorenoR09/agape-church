---
import { localizedPath, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: localizedPath(lang), label: t.nav.home },
  { href: localizedPath(lang, lang === 'es' ? 'nosotros' : 'about'), label: t.nav.about },
  { href: localizedPath(lang, lang === 'es' ? 'ministerios' : 'ministries'), label: t.nav.ministries },
  { href: localizedPath(lang, lang === 'es' ? 'devocionales' : 'devotionals'), label: t.nav.devotionals },
  { href: localizedPath(lang, lang === 'es' ? 'eventos' : 'events'), label: t.nav.events },
  { href: localizedPath(lang, lang === 'es' ? 'oracion' : 'prayer'), label: t.nav.prayer },
  { href: localizedPath(lang, lang === 'es' ? 'donaciones' : 'donations'), label: t.nav.donations },
];

const year = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Brand column -->
      <div>
        <a href={localizedPath(lang)} class="reveal-brand font-heading text-2xl font-bold text-white hover:text-secondary transition-colors">
          Agape Church
        </a>
        <p class="reveal-brand reveal-brand-delay mt-3 font-script text-white/85 text-xl leading-tight">
          {t.footer.tagline}
        </p>
        <p class="mt-4 text-white/70 text-sm leading-relaxed">
          {t.footer.address}
        </p>
        <p class="mt-1 text-white/70 text-sm">{t.footer.schedule}</p>
        <div class="mt-3 space-y-1">
          <a href={`tel:${t.footer.phone}`} class="block text-sm text-white/70 hover:text-secondary transition-colors">
            {t.footer.phone}
          </a>
          <a href={`mailto:${t.footer.email}`} class="block text-sm text-white/70 hover:text-secondary transition-colors">
            {t.footer.email}
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/80 mb-4">
          {t.footer.links_title}
        </h3>
        <ul class="space-y-2" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-white/70 hover:text-white transition-colors"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-widest text-white/80 mb-4">
          {t.footer.social_title}
        </h3>
        <div class="flex gap-4">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/IBRNAGAPE"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook de Agape Church"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-white/30 text-white/70 hover:border-secondary hover:text-secondary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/ibrn.agape/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de Agape Church"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-white/30 text-white/70 hover:border-secondary hover:text-secondary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@IBRNAgape"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube de Agape Church"
            class="w-9 h-9 flex items-center justify-center rounded-full border border-white/30 text-white/70 hover:border-secondary hover:text-secondary transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/20 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-xs text-white/50">
        © {year} Agape Church. {t.footer.rights}
      </p>
      <p class="text-xs text-white/40">
        {lang === 'es' ? 'Hecho con amor en Bogotá, Colombia' : 'Made with love in Bogotá, Colombia'}
      </p>
    </div>
  </div>
</footer>
