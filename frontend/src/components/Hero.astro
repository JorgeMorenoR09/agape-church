---
interface Props {
  tagline: string;
  subtitle: string;
  ctaPrimary: { text: string; href: string };
  ctaSecondary: { text: string; href: string };
}

const { tagline, subtitle, ctaPrimary, ctaSecondary } = Astro.props;
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  aria-label="Hero"
>
  <!-- Background gradient -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(135deg, #1a46ad 0%, #1756c2 40%, #2e7ae7 70%, #1a46ad 100%);"
    aria-hidden="true"
  ></div>

  <!-- Decorative pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle at 1px 1px, #ffffff 1px, transparent 0); background-size: 40px 40px;"
    aria-hidden="true"
  ></div>

  <!-- Soft top line accent -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-white/35" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
    <!-- Brand text -->
    <div class="mb-8" aria-hidden="true">
      <span class="reveal-brand reveal-step-1 font-heading text-white text-6xl sm:text-7xl lg:text-8xl font-semibold tracking-[0.02em] drop-shadow-[0_6px_16px_rgba(0,0,0,0.58)]">Ágape Church</span>
    </div>

    <!-- Main headline -->
    <h1 class="hero-tagline-spotlight text-center font-script text-4xl sm:text-5xl lg:text-6xl font-normal text-white leading-[1.08] mb-6 max-w-5xl mx-auto">
      <span class="hero-typewriter" data-typewriter>{tagline}</span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal-fade-up reveal-step-3 text-lg sm:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed">
      {subtitle}
    </p>

    <!-- CTA buttons -->
    <div class="reveal-fade-up reveal-step-4 flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={ctaPrimary.href}
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium bg-secondary text-white rounded-md hover:bg-primary transition-all hover:scale-105 shadow-lg shadow-black/20"
      >
        {ctaPrimary.text}
      </a>
      <a
        href={ctaSecondary.href}
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold border-2 border-white/60 text-white rounded-md hover:border-white hover:bg-white/10 transition-all"
      >
        {ctaSecondary.text}
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40" aria-hidden="true">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
