---
import { useTranslations, alternateLang, localizedPath, publicAsset } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const other = alternateLang(lang);

const navLinks = [
  { href: localizedPath(lang), label: t.nav.home },
  { href: localizedPath(lang, lang === 'es' ? 'nosotros' : 'about'), label: t.nav.about },
  { href: localizedPath(lang, lang === 'es' ? 'ministerios' : 'ministries'), label: t.nav.ministries },
  { href: localizedPath(lang, lang === 'es' ? 'devocionales' : 'devotionals'), label: t.nav.devotionals },
  { href: localizedPath(lang, lang === 'es' ? 'eventos' : 'events'), label: t.nav.events },
  { href: localizedPath(lang, lang === 'es' ? 'oracion' : 'prayer'), label: t.nav.prayer },
  { href: localizedPath(lang, lang === 'es' ? 'donaciones' : 'donations'), label: t.nav.donations },
];
---

<header class="sticky top-0 z-50 bg-surface/95 backdrop-blur-sm border-b border-gray-100 shadow-sm">
  <nav
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between"
    aria-label="Navegación principal"
  >
    <!-- Logo -->
    <a
      href={localizedPath(lang)}
      class="flex items-center max-w-[52vw] sm:max-w-[260px] lg:max-w-[300px] hover:opacity-80 transition-opacity"
      aria-label="Ágape Church — Inicio"
    >
      <img
        src={publicAsset('/images/blue-logo.png')}
        alt="Ágape Church"
        class="h-16 sm:h-20 lg:h-24 w-auto max-w-full object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {navLinks.slice(0, -1).map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="px-3 py-2 text-sm font-medium text-foreground/80 hover:text-primary hover:bg-primary/5 rounded-md transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right actions: donate + lang switcher + hamburger -->
    <div class="flex items-center gap-2">
      <!-- Donate CTA (desktop) -->
      <a
        href={localizedPath(lang, lang === 'es' ? 'donaciones' : 'donations')}
        class="hidden lg:inline-flex items-center px-4 py-2 text-sm font-semibold bg-secondary text-white rounded-md hover:bg-primary transition-colors"
      >
        {t.nav.donations}
      </a>

      <!-- Language switcher -->
      <a
        href={localizedPath(other)}
        class="px-3 py-1.5 text-xs font-semibold border border-secondary text-secondary rounded-md hover:bg-secondary hover:text-white transition-colors uppercase tracking-wide"
        aria-label={`Switch to ${other === 'en' ? 'English' : 'Español'}`}
      >
        {other}
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="nav-toggle"
        type="button"
        class="lg:hidden p-2 rounded-md text-foreground hover:bg-primary/10 transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-gray-100 bg-surface"
    role="navigation"
    aria-label="Menú móvil"
  >
    <ul class="px-4 py-3 space-y-1" role="list">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="block px-3 py-2.5 text-sm font-medium text-foreground hover:text-primary hover:bg-primary/5 rounded-md transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
