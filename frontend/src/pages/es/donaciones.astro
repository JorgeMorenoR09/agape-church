---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DonationSection from '../../components/DonationSection.astro';
import { absoluteUrl, useTranslations } from '../../i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);
const d = t.donations;
---

<BaseLayout
  title={`${d.title} — Ágape Church`}
  description={d.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/es/donaciones')}
  alternateUrl={absoluteUrl('/en/donations')}
>
  <!-- Page header -->
  <section class="bg-primary py-20 px-4 text-center" aria-labelledby="donations-page-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="donations-page-heading" class="font-heading text-5xl font-bold text-white mb-4">
        {d.title}
      </h1>
      <p class="font-script text-accent text-3xl font-normal">{t.hero.tagline}</p>
    </div>
  </section>

  <!-- Donation section component -->
  <DonationSection lang={lang} />

  <!-- Transparency note -->
  <section class="py-16 px-4 bg-background" aria-label="Transparencia">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">Transparencia y confianza</h2>
      <p class="text-foreground/70 leading-relaxed max-w-xl mx-auto">
        Todos los recursos recibidos son administrados con integridad y rendición de cuentas. Si tienes preguntas sobre el uso de los fondos, no dudes en contactarnos.
      </p>
      <a
        href={`mailto:${t.footer.email}`}
        class="inline-flex items-center gap-2 mt-6 text-sm font-medium text-secondary hover:text-primary transition-colors"
      >
        {t.footer.email}
      </a>
    </div>
  </section>
</BaseLayout>
