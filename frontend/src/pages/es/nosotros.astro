---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, localizedPath, useTranslations } from '../../i18n/utils';

const lang = 'es' as const;
const t = useTranslations(lang);
const a = t.about;
---

<BaseLayout
  title={`${a.title} — Agape Church`}
  description={a.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/es/nosotros')}
  alternateUrl={absoluteUrl('/en/about')}
>
  <!-- Page header -->
  <section class="bg-primary py-12 sm:py-20 px-4 text-center" aria-labelledby="about-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="about-heading" class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">{a.title}</h1>
      <p class="text-accent italic text-lg">"El amor hace la diferencia"</p>
    </div>
  </section>

  <!-- History -->
  <section class="py-8 sm:py-16 px-4 bg-background" aria-labelledby="history-heading">
    <div class="max-w-3xl mx-auto">
      <h2 id="history-heading" class="font-heading text-3xl sm:text-4xl font-bold text-primary mb-6">{a.history_title}</h2>
      <p class="text-foreground/75 text-base sm:text-lg leading-relaxed md:leading-loose">{a.history_body}</p>
    </div>
  </section>

  <!-- Vision + Mission -->
  <section class="py-16 px-4 bg-surface" aria-label="Visión y misión">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      <article class="bg-background rounded-xl p-8 border-l-4 border-secondary">
        <h2 class="font-heading text-2xl font-bold text-primary mb-4">{a.vision_title}</h2>
        <p class="text-foreground/75 leading-relaxed">{a.vision_body}</p>
      </article>
      <article class="bg-background rounded-xl p-8 border-l-4 border-accent">
        <h2 class="font-heading text-2xl font-bold text-primary mb-4">{a.mission_title}</h2>
        <p class="text-foreground/75 leading-relaxed">{a.mission_body}</p>
      </article>
    </div>
  </section>

  <!-- Values -->
  <section class="py-8 sm:py-16 px-4 bg-background" aria-labelledby="values-heading">
    <div class="max-w-4xl mx-auto">
      <h2 id="values-heading" class="font-heading text-3xl sm:text-4xl font-bold text-primary text-center mb-10">
        {a.values_title}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {a.values.map((v) => (
          <article class="bg-surface rounded-xl p-6 border border-gray-100 text-center shadow-sm">
            <h3 class="font-heading text-lg sm:text-xl font-bold text-primary mb-3">{v.title}</h3>
            <p class="text-foreground/70 text-sm sm:text-base leading-relaxed">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Join CTA -->
  <section class="py-8 sm:py-16 px-4 bg-secondary text-center" aria-label="Llamada a la acción">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white mb-4">
        {lang === 'es' ? '¿Listo para ser parte?' : 'Ready to be part?'}
      </h2>
      <p class="text-white/80 mb-8 text-base sm:text-lg">
        {lang === 'es' ? 'Únete a nuestra comunidad y descubre la diferencia que el amor puede hacer.' : 'Join our community and discover the difference love can make.'}
      </p>
      <a
        href={localizedPath(lang, 'oracion')}
        class="inline-flex items-center gap-2 px-8 py-3.5 font-semibold bg-white text-primary rounded-md hover:bg-white/90 transition-all hover:scale-105"
      >
        {lang === 'es' ? 'Escríbenos una oración' : 'Send us a prayer'}
      </a>
    </div>
  </section>
</BaseLayout>
