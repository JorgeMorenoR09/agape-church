---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import DevotionalCard from '../../components/DevotionalCard.astro';
import MinistryCard from '../../components/MinistryCard.astro';
import DonationSection from '../../components/DonationSection.astro';
import { useTranslations } from '../../i18n/utils';
import { devotionals } from '../../data/devotionals';
import { ministries } from '../../data/ministries';

const lang = 'es' as const;
const t = useTranslations(lang);
const siteURL = import.meta.env.PUBLIC_SITE_URL || 'https://agapechurch.com';

const recentDevotionals = devotionals.slice(0, 3);
const featuredMinistries = ministries.slice(0, 4);
---

<BaseLayout
  title="Ágape Church — El amor hace la diferencia"
  description="Ágape Church es una comunidad de fe en Bogotá que cree en el poder transformador del amor de Cristo. Únete a nosotros cada domingo."
  lang={lang}
  canonicalURL={`${siteURL}/es/`}
  alternateUrl={`${siteURL}/en/`}
>
  <!-- Hero -->
  <Hero
    tagline={t.hero.tagline}
    subtitle={t.hero.subtitle}
    ctaPrimary={{ text: t.hero.cta_primary, href: '/es/nosotros' }}
    ctaSecondary={{ text: t.hero.cta_secondary, href: '/es/ministerios' }}
  />

  <!-- Devocionales recientes -->
  <section class="py-20 px-4 bg-background" aria-labelledby="devotionals-home-heading">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 id="devotionals-home-heading" class="font-heading text-4xl font-bold text-primary mb-3">
          {t.home.devotionals_title}
        </h2>
        <p class="text-foreground/60 text-base max-w-xl mx-auto">{t.home.devotionals_subtitle}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {recentDevotionals.map((d) => (
          <DevotionalCard
            slug={d.slug}
            title={d.title[lang]}
            excerpt={d.excerpt[lang]}
            date={d.date}
            verseRef={d.verseRef}
            lang={lang}
            readMoreLabel={t.devotionals.read_more}
          />
        ))}
      </div>

      <div class="text-center">
        <a
          href="/es/devocionales"
          class="inline-flex items-center gap-2 text-sm font-medium text-secondary hover:text-primary border border-secondary hover:border-primary rounded-md px-6 py-2.5 transition-colors"
        >
          {t.home.devotionals_cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Ministerios -->
  <section class="py-20 px-4 bg-surface" aria-labelledby="ministries-home-heading">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 id="ministries-home-heading" class="font-heading text-4xl font-bold text-primary mb-3">
          {t.home.ministries_title}
        </h2>
        <p class="text-foreground/60 text-base max-w-xl mx-auto">{t.home.ministries_subtitle}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
        {featuredMinistries.map((m) => (
          <MinistryCard
            icon={m.icon}
            name={m.name[lang]}
            description={m.description[lang]}
            href={`/es/ministerios#${m.slug}`}
          />
        ))}
      </div>

      <div class="text-center">
        <a
          href="/es/ministerios"
          class="inline-flex items-center gap-2 text-sm font-medium text-secondary hover:text-primary border border-secondary hover:border-primary rounded-md px-6 py-2.5 transition-colors"
        >
          {t.home.ministries_cta}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Donation CTA -->
  <DonationSection lang={lang} />
</BaseLayout>
