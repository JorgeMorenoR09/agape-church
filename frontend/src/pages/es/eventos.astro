---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { absoluteUrl, useTranslations } from '../../i18n/utils';
import { events } from '../../data/events';

const lang = 'es' as const;
const t = useTranslations(lang);
const e = t.events;
---

<BaseLayout
  title={`${e.title} — Ágape Church`}
  description={e.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/es/eventos')}
  alternateUrl={absoluteUrl('/en/events')}
>
  <!-- Page header -->
  <section class="bg-primary py-20 px-4 text-center" aria-labelledby="events-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="events-heading" class="font-heading text-5xl font-bold text-white mb-4">{e.title}</h1>
      <p class="text-white/75 text-lg">{e.subtitle}</p>
    </div>
  </section>

  <!-- Events list -->
  <section class="py-20 px-4 bg-background" aria-label="Lista de eventos">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {events.map((ev) => (
          <EventCard
            title={ev.title[lang]}
            description={ev.description[lang]}
            date={ev.date}
            time={ev.time}
            location={ev.location[lang]}
            dateLabel={e.date_label}
            timeLabel={e.time_label}
            locationLabel={e.location_label}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
