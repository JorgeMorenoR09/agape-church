---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DonationSection from '../../components/DonationSection.astro';
import { absoluteUrl, useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);
const d = t.donations;
---

<BaseLayout
  title={`${d.title} — Agape Church`}
  description={d.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/en/donations')}
  alternateUrl={absoluteUrl('/es/donaciones')}
>
  <section class="bg-primary py-20 px-4 text-center" aria-labelledby="donations-en-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="donations-en-heading" class="font-heading text-5xl font-bold text-white mb-4">
        {d.title}
      </h1>
      <p class="font-script text-accent text-3xl font-normal">{t.hero.tagline}</p>
    </div>
  </section>

  <DonationSection lang={lang} />

  <section class="py-16 px-4 bg-background" aria-label="Transparency">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading text-2xl font-bold text-primary mb-4">Transparency & Trust</h2>
      <p class="text-foreground/70 leading-relaxed max-w-xl mx-auto">
        All resources received are managed with integrity and accountability. If you have questions about the use of funds, feel free to contact us.
      </p>
      <a
        href={`mailto:${t.footer.email}`}
        class="inline-flex items-center gap-2 mt-6 text-sm font-medium text-secondary hover:text-primary transition-colors"
      >
        {t.footer.email}
      </a>
    </div>
  </section>
</BaseLayout>
