---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DevotionalCard from '../../../components/DevotionalCard.astro';
import { absoluteUrl, useTranslations } from '../../../i18n/utils';
import { devotionals } from '../../../data/devotionals';

const lang = 'en' as const;
const t = useTranslations(lang);
const d = t.devotionals;
---

<BaseLayout
  title={`${d.title} — Agape Church`}
  description={d.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/en/devotionals')}
  alternateUrl={absoluteUrl('/es/devocionales')}
>
  <section class="bg-primary py-20 px-4 text-center" aria-labelledby="devotionals-en-page-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="devotionals-en-page-heading" class="font-heading text-5xl font-bold text-white mb-4">{d.title}</h1>
      <p class="text-white/75 text-lg">{d.subtitle}</p>
    </div>
  </section>

  <section class="py-20 px-4 bg-background" aria-label="Devotionals list">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {devotionals.map((dev) => (
          <DevotionalCard
            slug={dev.slug}
            title={dev.title[lang]}
            excerpt={dev.excerpt[lang]}
            date={dev.date}
            verseRef={dev.verseRef}
            lang={lang}
            readMoreLabel={d.read_more}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
