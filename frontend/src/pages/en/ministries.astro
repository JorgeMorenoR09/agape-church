---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { absoluteUrl, localizedPath, useTranslations } from '../../i18n/utils';
import { ministries } from '../../data/ministries';

const lang = 'en' as const;
const t = useTranslations(lang);
const m = t.ministries;
---

<BaseLayout
  title={`${m.title} — Ágape Church`}
  description={m.meta_description}
  lang={lang}
  canonicalURL={absoluteUrl('/en/ministries')}
  alternateUrl={absoluteUrl('/es/ministerios')}
>
  <section class="bg-primary py-20 px-4 text-center" aria-labelledby="ministries-en-heading">
    <div class="max-w-3xl mx-auto">
      <h1 id="ministries-en-heading" class="font-heading text-5xl font-bold text-white mb-4">{m.title}</h1>
      <p class="text-white/75 text-lg">{m.subtitle}</p>
    </div>
  </section>

  <section class="py-20 px-4 bg-background" aria-label="Ministries list">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {ministries.map((ministry) => (
          <article
            id={ministry.slug}
            class="group bg-surface rounded-xl p-8 border border-gray-100 shadow-sm hover:shadow-md hover:border-secondary/30 transition-all duration-300 scroll-mt-20"
          >
            <div class="text-5xl mb-5" aria-hidden="true">{ministry.icon}</div>
            <h2 class="font-heading text-2xl font-bold text-primary mb-4 group-hover:text-secondary transition-colors">
              {ministry.name[lang]}
            </h2>
            <p class="text-foreground/70 leading-relaxed">{ministry.description[lang]}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 px-4 bg-secondary text-center" aria-label="Call to action">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-heading text-3xl font-bold text-white mb-4">Want to join a ministry?</h2>
      <p class="text-white/80 mb-8">Send us a message and we'll help you find your place according to your gifts and passions.</p>
      <a
        href={localizedPath(lang, 'prayer')}
        class="inline-flex items-center gap-2 px-8 py-3.5 font-semibold bg-secondary text-white rounded-md hover:bg-primary transition-all hover:scale-105"
      >
        Contact us
      </a>
    </div>
  </section>
</BaseLayout>
